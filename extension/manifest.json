{
  "manifest_version": 3,
  "name": "YT Remote Extension",
  "version": "1.0",
  "description": "Remote control for YouTube playback via Pixel 3XL Hub.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
